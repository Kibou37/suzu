generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum CarCondition {
  NEW
  USED
}

enum BodyType {
  SEDAN
  SUV
  HATCHBACK
  CROSSOVER
  PICKUP
}

enum Transmission {
  MANUAL
  AUTOMATIC
  CVT
}

enum FuelType {
  PETROL
  DIESEL
  HYBRID
}

enum BookingType {
  TEST_DRIVE
  SERVICE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum ColorType {
  BODY
  INTERIOR
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  phone          String?
  passwordHash   String
  firstName      String?
  lastName       String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  bookings       Booking[]
  configurations Configuration[]
  reviews        Review[]
}

model Car {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  brand        String       @default("Suzuki")
  condition    CarCondition @default(NEW)
  year         Int
  price        Decimal      @db.Decimal(12, 2)
  mileage      Int          @default(0)
  bodyType     BodyType
  fuelType     FuelType
  transmission Transmission
  trim         String?
  description  String?      @db.Text
  horsepower   Int?
  isFeatured   Boolean      @default(false)
  isOffer      Boolean      @default(false)
  offerLabel   String?
  images       Json         @default("[]")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  variants     CarVariant[]
  bookings     Booking[]
  reviews      Review[]

  @@index([condition, price])
  @@index([bodyType])
}

model CarVariant {
  id             String           @id @default(cuid())
  carId          String
  car            Car              @relation(fields: [carId], references: [id], onDelete: Cascade)
  name           String
  basePrice      Decimal          @db.Decimal(12, 2)
  variantOptions CarVariantOption[]
  configurations Configuration[]

  @@index([carId])
}

model Color {
  id       String    @id @default(cuid())
  name     String
  hexCode  String
  type     ColorType
}

model Option {
  id             String             @id @default(cuid())
  name           String
  description    String?            @db.Text
  price          Decimal            @db.Decimal(12, 2)
  category       String?
  variantOptions CarVariantOption[]
}

model CarVariantOption {
  variantId String
  optionId  String
  variant   CarVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  option    Option     @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([variantId, optionId])
}

model Configuration {
  id              String     @id @default(cuid())
  userId          String?
  user            User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  variantId       String
  variant         CarVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  bodyColorId     String?
  interiorColorId String?
  selectedOptions Json       @default("[]")
  totalPrice      Decimal    @db.Decimal(12, 2)
  shareToken      String?    @unique
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Booking {
  id            String        @id @default(cuid())
  type          BookingType
  status        BookingStatus @default(PENDING)
  userId        String?
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  carId         String?
  car           Car?          @relation(fields: [carId], references: [id], onDelete: SetNull)
  scheduledAt   DateTime
  customerName  String
  customerPhone String
  customerEmail String?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([scheduledAt, type])
}

model ServiceSlot {
  id          String      @id @default(cuid())
  startsAt    DateTime
  endsAt      DateTime
  type        BookingType
  maxBookings Int         @default(1)
  isBlocked   Boolean     @default(false)
}

model Review {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  carId       String?
  car         Car?     @relation(fields: [carId], references: [id], onDelete: SetNull)
  authorName  String
  rating      Int
  title       String?
  content     String   @db.Text
  isPublished Boolean  @default(false)
  images      Json     @default("[]")
  videoUrl    String?
  createdAt   DateTime @default(now())
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  content     String    @db.Text
  coverImage  String?
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model FAQ {
  id        String @id @default(cuid())
  question  String
  answer    String @db.Text
  category  String?
  sortOrder Int    @default(0)
}

model Promotion {
  id          String    @id @default(cuid())
  title       String
  description String?   @db.Text
  image       String?
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean   @default(true)
}
