{
  "name": "suzuki-dealer",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @suzuki/shared build && pnpm --filter @suzuki/frontend --filter @suzuki/backend --parallel dev",
    "dev:frontend": "pnpm --filter @suzuki/frontend dev",
    "dev:backend": "pnpm --filter @suzuki/backend dev",
    "build": "pnpm --filter @suzuki/shared build && pnpm --filter @suzuki/frontend --filter @suzuki/backend build",
    "lint": "pnpm run --recursive lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down && docker volume rm suzuki_root_node_modules suzuki_backend_node_modules suzuki_frontend_node_modules suzuki_shared_node_modules 2>/dev/null; docker compose up -d --build",
    "docker:logs": "docker compose logs -f",
    "db:migrate": "pnpm --filter @suzuki/backend prisma:migrate",
    "db:seed": "pnpm --filter @suzuki/backend prisma:seed",
    "assets:viewer-discover": "node scripts/discover-globalsuzuki-viewers.mjs",
    "assets:viewer-map": "node scripts/generate-exterior-360-map.mjs",
    "assets:viewer-sync": "node scripts/sync-viewer-assets.mjs",
    "assets:viewer-sync:all": "node scripts/discover-globalsuzuki-viewers.mjs && node scripts/generate-exterior-360-map.mjs && node scripts/sync-viewer-assets.mjs",
    "assets:viewer-sync:all-models": "node scripts/sync-viewer-assets.mjs --all",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.8.0"
}
